# Edge Function 환경변수 설정 파일
# 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요.
# .env.local 은 절대 git에 커밋하지 마세요.
#
# Supabase Dashboard > Project Settings > Edge Functions > Secrets 에도 동일하게 등록해야 합니다.

# ──────────────────────────────────────────────
# AI Provider 설정
# ──────────────────────────────────────────────
# 사용할 AI 프로바이더를 선택하세요: claude | openai | gemini
AI_PROVIDER=openai

# OpenAI (AI_PROVIDER=openai 일 때 필요)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini        # gpt-4o, gpt-4o-mini, gpt-4-turbo 등

# Anthropic Claude (AI_PROVIDER=claude 일 때 필요)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5   # claude-opus-4-5, claude-haiku-3-5 등

# Google Gemini (AI_PROVIDER=gemini 일 때 필요)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash    # gemini-1.5-pro, gemini-2.0-flash 등

# ──────────────────────────────────────────────
# Supabase (Edge Function 내부 자동 제공 — 보통 수동 설정 불필요)
# ──────────────────────────────────────────────
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (analyze-session이 DB에 직접 쓸 때 사용)
